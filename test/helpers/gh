#!/usr/bin/env bash
# Mock gh CLI for bats tests.
#
# Routes calls based on command/subcommand, applies any --jq filter via real jq,
# and reads response data from MOCK_* environment variables:
#
#   MOCK_APPS_RESPONSE            JSON for: gh api .../apps
#   MOCK_APPS_EXIT                Non-zero exit code to simulate API failure
#   MOCK_REVIEWS_RESPONSE         JSON for: gh api .../reviews
#   MOCK_PR_LIST_RESPONSE         JSON for: gh pr list  (ralph branch PRs)
#   MOCK_PR_LIST_EXIT             Non-zero exit code to simulate pr list failure
#   MOCK_FEATURE_PR_LIST_RESPONSE JSON for: gh pr list --head <branch>  (feat PR check)
#   MOCK_PR_VIEW_COMMENTS_RESPONSE  JSON for: gh pr view --json comments
#   MOCK_PR_VIEW_COMMITS_RESPONSE   JSON for: gh pr view --json commits
#   MOCK_ISSUE_LIST_RESPONSE      JSON for: gh issue list
#   MOCK_ISSUE_VIEW_RESPONSE      JSON for: gh issue view <N> --json state
#
#   MOCK_AUTH_STATUS_EXIT         Non-zero to simulate unauthenticated (default 0)
#   MOCK_REPO_VIEW_RESPONSE       JSON for: gh repo view --json nameWithOwner
#   MOCK_REPO_VIEW_EXIT           Non-zero to simulate inference failure (default 0)
#   MOCK_RATE_LIMIT_EXIT          Non-zero to simulate API unreachable (default 0)

set -euo pipefail

JQ_FILTER=""
JSON_FIELDS=""
HAS_HEAD="false"
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --jq)     JQ_FILTER="$2";   shift 2 ;;
    --json)   JSON_FIELDS="$2"; shift 2 ;;
    --head)   HAS_HEAD="true";  shift 2 ;;
    -f)       shift 2 ;;
    --repo|--base|--state|--label|--limit) shift 2 ;;
    *)        POSITIONAL+=("$1"); shift ;;
  esac
done

apply_jq() {
  local data="$1"
  if [[ -n "$JQ_FILTER" ]]; then
    printf '%s' "$data" | jq -r "$JQ_FILTER"
  else
    printf '%s\n' "$data"
  fi
}

# Avoid ${VAR:-{...}} patterns — the } in the default closes ${...} early in bash.
# Use intermediate variables so the } in the default value is expanded safely.
_default_obj='{"comments":[]}'
_default_commits='{"commits":[]}'
MOCK_APPS_RESPONSE="${MOCK_APPS_RESPONSE:-[]}"
MOCK_REVIEWS_RESPONSE="${MOCK_REVIEWS_RESPONSE:-[]}"
MOCK_PR_LIST_RESPONSE="${MOCK_PR_LIST_RESPONSE:-[]}"
MOCK_FEATURE_PR_LIST_RESPONSE="${MOCK_FEATURE_PR_LIST_RESPONSE:-[]}"
MOCK_PR_VIEW_COMMENTS_RESPONSE="${MOCK_PR_VIEW_COMMENTS_RESPONSE:-$_default_obj}"
MOCK_PR_VIEW_COMMITS_RESPONSE="${MOCK_PR_VIEW_COMMITS_RESPONSE:-$_default_commits}"
MOCK_ISSUE_LIST_RESPONSE="${MOCK_ISSUE_LIST_RESPONSE:-[]}"
_default_issue_view='{"state":"OPEN"}'
MOCK_ISSUE_VIEW_RESPONSE="${MOCK_ISSUE_VIEW_RESPONSE:-$_default_issue_view}"

CMD="${POSITIONAL[0]:-}"
SUBCMD="${POSITIONAL[1]:-}"

case "$CMD" in
  api)
    ENDPOINT="$SUBCMD"
    if [[ "$ENDPOINT" == *"/apps" ]]; then
      [[ "${MOCK_APPS_EXIT:-0}" == "0" ]] || exit "${MOCK_APPS_EXIT}"
      apply_jq "$MOCK_APPS_RESPONSE"
    elif [[ "$ENDPOINT" == *"/reviews" ]]; then
      apply_jq "$MOCK_REVIEWS_RESPONSE"
    elif [[ "$ENDPOINT" == *"/pulls" ]]; then
      apply_jq "$MOCK_FEATURE_PR_LIST_RESPONSE"
    elif [[ "$ENDPOINT" == "/rate_limit" ]]; then
      [[ "${MOCK_RATE_LIMIT_EXIT:-0}" == "0" ]] || exit "${MOCK_RATE_LIMIT_EXIT}"
      echo '{}'
    fi
    ;;
  auth)
    case "$SUBCMD" in
      status)
        [[ "${MOCK_AUTH_STATUS_EXIT:-0}" == "0" ]] || exit "${MOCK_AUTH_STATUS_EXIT}"
        ;;
    esac
    ;;
  pr)
    case "$SUBCMD" in
      list)
        if [[ "$HAS_HEAD" == "true" ]]; then
          apply_jq "$MOCK_FEATURE_PR_LIST_RESPONSE"
        else
          [[ "${MOCK_PR_LIST_EXIT:-0}" == "0" ]] || { echo "${MOCK_PR_LIST_ERROR:-gh pr list error}"; exit "${MOCK_PR_LIST_EXIT}"; }
          apply_jq "$MOCK_PR_LIST_RESPONSE"
        fi
        ;;
      view)
        if [[ "$JSON_FIELDS" == "commits" ]]; then
          apply_jq "$MOCK_PR_VIEW_COMMITS_RESPONSE"
        else
          apply_jq "$MOCK_PR_VIEW_COMMENTS_RESPONSE"
        fi
        ;;
    esac
    ;;
  repo)
    case "$SUBCMD" in
      view)
        [[ "${MOCK_REPO_VIEW_EXIT:-0}" == "0" ]] || exit "${MOCK_REPO_VIEW_EXIT}"
        _default_repo_view='{"nameWithOwner":"owner/repo"}'
        MOCK_REPO_VIEW_RESPONSE="${MOCK_REPO_VIEW_RESPONSE:-$_default_repo_view}"
        apply_jq "$MOCK_REPO_VIEW_RESPONSE"
        ;;
    esac
    ;;
  issue)
    case "$SUBCMD" in
      list)
        apply_jq "$MOCK_ISSUE_LIST_RESPONSE"
        ;;
      view)
        apply_jq "$MOCK_ISSUE_VIEW_RESPONSE"
        ;;
    esac
    ;;
esac
